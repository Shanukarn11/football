#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

BASE=(docker compose -f compose.yaml)
DEV=(docker compose -f compose.yaml -f compose.dev.yaml)

ensure_env() {
    if [[ ! -f .env ]]; then
        cp .env.example .env
        echo "Created .env from .env.example. Update its database credentials, then rerun the command."
        exit 1
    fi
}

usage() {
    cat <<'EOF'
IKF Docker helper

Development:
  ./ikfctl init                 Create local folders and .env
  ./ikfctl dev                  Build and start development
  ./ikfctl stop                 Stop development containers
  ./ikfctl logs                 Follow web logs
  ./ikfctl update               Git pull and rebuild development

Django:
  ./ikfctl check                Run Django checks
  ./ikfctl test                 Run Django tests
  ./ikfctl makemigrations [app] Generate migrations (development only)
  ./ikfctl migrate              Apply migrations
  ./ikfctl static               Run collectstatic
  ./ikfctl shell                Open Django shell
  ./ikfctl bash                 Open a container shell

Production:
  ./ikfctl deploy               Pull image, check, migrate, collect static, deploy
  ./ikfctl status               Show production service status
EOF
}

command="${1:-help}"
shift || true

case "$command" in
    init)
        mkdir -p docker-data/static docker-data/media
        if [[ ! -f .env ]]; then
            cp .env.example .env
            echo "Created .env. Edit it before starting Django."
        else
            echo ".env already exists."
        fi
        ;;
    dev)
        ensure_env
        "${DEV[@]}" up -d --build
        "${DEV[@]}" ps
        ;;
    stop)
        "${DEV[@]}" down
        ;;
    logs)
        "${DEV[@]}" logs -f --tail=200 web
        ;;
    update)
        ensure_env
        git pull --ff-only
        "${DEV[@]}" up -d --build
        "${DEV[@]}" ps
        ;;
    check)
        ensure_env
        "${DEV[@]}" run --rm --no-deps web python manage.py check
        ;;
    test)
        ensure_env
        "${DEV[@]}" run --rm --no-deps web python manage.py test "$@"
        ;;
    makemigrations)
        ensure_env
        app="${1:-main}"
        "${DEV[@]}" run --rm --no-deps web python manage.py makemigrations "$app"
        ;;
    migrate)
        ensure_env
        "${DEV[@]}" run --rm --no-deps web python manage.py migrate
        ;;
    static)
        ensure_env
        "${DEV[@]}" run --rm --no-deps web python manage.py collectstatic --noinput
        ;;
    shell)
        ensure_env
        "${DEV[@]}" run --rm --no-deps web python manage.py shell
        ;;
    bash)
        ensure_env
        "${DEV[@]}" run --rm --no-deps web bash
        ;;
    deploy)
        ensure_env
        "${BASE[@]}" pull web
        "${BASE[@]}" run --rm --no-deps web python manage.py check --deploy
        "${BASE[@]}" run --rm --no-deps web python manage.py migrate --noinput
        "${BASE[@]}" run --rm --no-deps web python manage.py collectstatic --noinput
        "${BASE[@]}" up -d --no-deps web
        "${BASE[@]}" ps
        ;;
    status)
        "${BASE[@]}" ps
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "Unknown command: $command" >&2
        usage >&2
        exit 2
        ;;
esac
